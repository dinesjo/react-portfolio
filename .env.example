# Server-side only. Never rename this to a VITE_* variable or expose it to React.
OLLAMA_API_KEY=replace-with-an-ollama-cloud-api-key

# Optional Ollama Cloud generator override.
OLLAMA_MODEL=gemma4:31b

# Full portfolio context and answer limits. Invalid values fall back safely.
OLLAMA_CONTEXT_TOKENS=131072
OLLAMA_MAX_OUTPUT_TOKENS=1200

# Optional local/runtime port override. Defaults to 8080.
PORT=8080
