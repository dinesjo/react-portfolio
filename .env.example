# Server-side only. Never rename this to a VITE_* variable or expose it to React.
OLLAMA_API_KEY=replace-with-an-ollama-cloud-api-key

# Local Ollama supplies embeddings; generation still uses Ollama Cloud above.
OLLAMA_EMBEDDING_URL=http://127.0.0.1:11434

# Qdrant is exposed on loopback by Compose for host-side development.
QDRANT_URL=http://127.0.0.1:6333

# Containers reach the native Ollama daemon through the Docker host gateway.
OLLAMA_EMBEDDING_DOCKER_URL=http://host.docker.internal:11434

# Optional local/runtime port override. Defaults to 8080.
PORT=8080
