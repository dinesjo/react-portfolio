{
  "name": "react-portfolio",
  "private": true,
  "version": "0.0.0",
  "homepage": "https://linusdinesjo.github.io",
  "type": "module",
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -b master -d dist",
    "dev": "node --env-file-if-exists=.env.local server/index.js",
    "dev:static": "vite",
    "prebuild": "npm run optimize-images",
    "build": "vite build",
    "optimize-images": "node scripts/optimize-images.mjs",
    "vector:up": "docker compose --env-file .env.local up -d qdrant",
    "retrieval:evaluate": "node --env-file-if-exists=.env.local scripts/evaluate-retrieval.mjs",
    "start": "node --env-file-if-exists=.env.local server/index.js --production",
    "test": "node --test server/*.test.js",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.10.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.15",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "gh-pages": "^6.0.0",
    "postcss": "^8.4.29",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.3",
    "vite": "^7.0.4"
  }
}
